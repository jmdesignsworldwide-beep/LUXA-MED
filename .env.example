# =============================================================================
# LUXA-MED · Variables de entorno (PLANTILLA)
# =============================================================================
# Este archivo SÍ se sube al repo. NO contiene valores reales, solo los nombres.
# Para uso local: copia este archivo a .env.local y pega tus valores ahí.
#   cp .env.example .env.local
#
# .env.local está en .gitignore y NUNCA se sube al repositorio.
# =============================================================================

# --- Supabase: expuestas al navegador (cliente). Prefijo NEXT_PUBLIC_ ---
# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase: SOLO servidor. SIN prefijo NEXT_PUBLIC_ (nunca exponer) ---
# Settings → API → Project API keys → service_role (secret)
# Da acceso total saltándose RLS. Solo en código de servidor / Vercel "Sensitive".
SUPABASE_SERVICE_ROLE_KEY=
